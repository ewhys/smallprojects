void updateSnake (int length)
{
//FRONT
//1 is right
//2 is left
//3 is up
//4 is down
int front = length-1;
int back = 0;
    if (direct[front] == 1)
    {
      frontx ++;
    }
    else if (direct[front] == 2)
    {
      frontx = frontx - 1;
    }
    
    else if (direct[front] == 3)
    {
      fronty = fronty - 1;
    }
    else
    {
      fronty = fronty + 1;
    }

//BACK
    if (direct[back] == 1)
    {
      backx ++;
    }
    else if (direct[back] == 2)
    {
      backx = backx - 1;
    }
    
    else if (direct[back] == 3)
    {
      backy = backy - 1;
    }

    else 
    {
      backy = backy + 1;
    }
    
    
  
}
