void updateList (int length, int next)
{
  int n = next;
  if (next == 1 && direct [length-1] == 2 || next == 2 && direct[length-1] ==1)
  {
    n = direct [length - 1];
    
  }
  if (next == 3 && direct [length-1] == 4 || next == 4 && direct[length-1] == 3)
  {
    n = direct [length -1];
    
  }
  for (int i = 0; i<length-1;i++)
  {
    direct [i] = direct [i+1];
  }
  direct[length-1] = n;
  
}

